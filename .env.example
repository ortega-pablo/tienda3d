# ============================================================
# Plastik 3D — Environment variables
# Copy to .env (never commit .env)
# ============================================================

# --- Database ---
POSTGRES_USER=tienda3d
POSTGRES_PASSWORD=changeme
POSTGRES_DB=tienda3d
POSTGRES_PORT=5432

# Used by Prisma in the api container (host=db is the docker service name)
DATABASE_URL=postgresql://tienda3d:changeme@db:5432/tienda3d?schema=public

# --- API ---
API_PORT=3001
API_NODE_ENV=development
API_JWT_SECRET=replace-with-32-byte-random-string
API_JWT_EXPIRES_IN=15m
API_REFRESH_SECRET=replace-with-another-32-byte-random
API_REFRESH_EXPIRES_IN=8h
API_CORS_ORIGIN=http://localhost:3000

# --- Web ---
WEB_PORT=3000
# Internal URL used by Next.js server (RSC + route handlers) to reach the API
# inside the docker network. The browser never hits the API directly — it goes
# through the Next.js /api/* proxy, so cookies live on the web domain.
API_INTERNAL_URL=http://api:3001

# --- Seed ---
SEED_ADMIN_EMAIL=admin@plastik.local
SEED_ADMIN_PASSWORD=admin123

# --- Integraciones externas (todas deshabilitadas por defecto) ---
# MercadoLibre — sync de publicaciones y precios
INTEGRATION_MELI_ENABLED=false
MELI_CLIENT_ID=
MELI_CLIENT_SECRET=
MELI_REFRESH_TOKEN=

# ARCA / AFIP — facturación electrónica
INTEGRATION_ARCA_ENABLED=false
ARCA_CUIT=
ARCA_CERT=
ARCA_KEY=

# WhatsApp Business — envío de cotizaciones
INTEGRATION_WHATSAPP_ENABLED=false
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
