{
  "name": "tienda3d",
  "private": true,
  "version": "0.1.0",
  "description": "Plastik 3D — Sistema de cotización, costeo y stock",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "docker compose up",
    "dev:build": "docker compose up --build",
    "dev:down": "docker compose down",
    "dev:reset": "docker compose down -v",
    "logs": "docker compose logs -f",
    "logs:api": "docker compose logs -f api",
    "logs:web": "docker compose logs -f web",
    "logs:db": "docker compose logs -f db",
    "api": "pnpm --filter @tienda3d/api",
    "web": "pnpm --filter @tienda3d/web",
    "shared": "pnpm --filter @tienda3d/shared",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yml,yaml}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
